<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Newsletter – {{month}} {{year}} | Chorlton Bikes</title>
    <link rel="canonical" href="{{canonicalUrl}}">
    <link rel="stylesheet" href="../styles.css">
    <link rel="icon" type="image/png" href="../assets/images/logo.png">
    <style>
        body { margin: 0; font-family: Arial, sans-serif; font-size: 16px; line-height: 1.5; color: #333333; }
        .inner { max-width: 600px; margin: 0 auto; padding: 0 24px; box-sizing: border-box; }
        .newsletter-logo-block { width: 100%; background: #ffffff; padding: 32px 24px; text-align: center; box-sizing: border-box; }
        .newsletter-logo-block .inner { padding: 0 24px; }
        .newsletter-logo-block img { max-width: 280px; width: 100%; height: auto; display: block; margin: 0 auto; }
        .newsletter-hello-block { width: 100%; background: #008037; padding: 28px 24px; box-sizing: border-box; }
        .newsletter-hello-block .inner { color: #fff; text-align: center; }
        .newsletter-hello-block .intro { font-size: 1.5rem; font-weight: bold; margin: 0 0 12px 0; }
        .newsletter-hello-block p { margin: 0; color: #fff; }
        .newsletter-hello-block p + p { margin-top: 12px; }
        .newsletter-january-block { width: 100%; background: #ffffff; padding: 24px 0; box-sizing: border-box; }
        .newsletter-january-block .inner { display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap; }
        .newsletter-january-block .title-col { flex: 0 0 auto; }
        .newsletter-january-block .title-col .month { font-size: 1.5rem; font-weight: bold; color: #008037; margin: 0; line-height: 1.2; }
        .newsletter-january-block .title-col .year { font-size: 1.5rem; font-weight: bold; color: #008037; margin: 0; }
        .newsletter-january-block .text-col { flex: 1; min-width: 0; margin: 0; color: #333; }
        .newsletter-article-block { width: 100%; padding: 24px 0; box-sizing: border-box; }
        .newsletter-article-block.block-cream { background: #fffde7; }
        .newsletter-article-block.block-white { background: #ffffff; }
        .newsletter-article-block h2 { font-size: 1.75rem; color: #333; margin: 0 0 0.5rem 0; font-weight: bold; }
        .newsletter-article-block ul { margin: 0 0 1rem 0; padding-left: 0; list-style: none; }
        .newsletter-article-block ul li { margin-bottom: 0.5rem; padding-left: 0; }
        .newsletter-article-block .newsletter-img { width: 100%; max-width: 100%; height: auto; display: block; margin: 0 0 1rem 0; border-radius: 4px; }
        .newsletter-image-grid { display: grid; gap: 12px; margin: 0 0 1rem 0; }
        .newsletter-image-grid.two-col { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .newsletter-image-grid.three-col { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .newsletter-image-grid .newsletter-img { margin: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
        .newsletter-image-grid.two-col .newsletter-img { aspect-ratio: 4 / 5; }
        .newsletter-image-grid.three-col .newsletter-img { aspect-ratio: 1 / 1; }
        .newsletter-img.square-crop { aspect-ratio: 1 / 1; object-fit: cover; }
        .newsletter-img.square-crop.center { object-position: center; }
        .newsletter-img.square-crop.top { object-position: top center; }
        .newsletter-cta { margin: 1.25rem 0 0; }
        .newsletter-cta a { display: block; width: 100%; box-sizing: border-box; background: #ff8210; color: #fff !important; padding: 14px 20px; text-align: center; text-decoration: none; font-weight: bold; font-size: 15px; }
        .newsletter-cta a:hover { opacity: 0.9; }
        .newsletter-thankyou-block { width: 100%; background: #ffffff; padding: 24px 0 32px; box-sizing: border-box; }
        .newsletter-thankyou-block .inner { display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap; }
        .newsletter-thankyou-block .title-col { flex: 0 0 auto; }
        .newsletter-thankyou-block .title-col h2 { font-size: 1.75rem; font-weight: bold; color: #008037; margin: 0; line-height: 1.2; }
        .newsletter-thankyou-block .text-col { flex: 1; min-width: 0; margin: 0; color: #333; }
        @media (max-width: 640px) {
            .newsletter-image-grid.two-col,
            .newsletter-image-grid.three-col { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body id="top">
    <nav class="navbar">
        <div class="container">
            <a href="../index.html" class="nav-brand" aria-label="Chorlton Bikes Home">
                <img src="../assets/images/logo-white.png" alt="Chorlton Bikes Logo" class="logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                <span class="logo-text">Chorlton Bikes</span>
            </a>
            <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-links">
                <li><a href="../index.html#services">Services</a></li>
                <li><a href="../index.html#membership">Join Us</a></li>
                <li><a href="../index.html#donate">Donate</a></li>
                <li><a href="../index.html#about">About</a></li>
            </ul>
            <div class="mobile-menu-overlay"></div>
        </div>
    </nav>

    <div class="newsletter-logo-block">
        <div class="inner">
            <img src="../assets/images/logo-green.png" alt="Chorlton Bikes" width="280" height="auto">
        </div>
    </div>

    <div class="newsletter-hello-block">
        <div class="inner">
            <p class="intro">{{intro.greeting}}</p>
            {{#each intro.paragraphs}}
            <p>{{this}}</p>
            {{/each}}
        </div>
    </div>

    <div class="newsletter-january-block">
        <div class="inner">
            <div class="title-col">
                <p class="month">{{month}}</p>
                <p class="year">{{year}}</p>
            </div>
            <div class="text-col">
                <p style="margin: 0;">{{monthIntro}}</p>
            </div>
        </div>
    </div>

    {{#each sections}}
    <div class="newsletter-article-block {{blockClass}}">
        <div class="inner">
            {{#if imagesHtml}}
            {{{imagesHtml}}}
            {{/if}}
            <h2>{{title}}</h2>
            <ul>
                {{#each bullets}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{{ctaHtml}}}
        </div>
    </div>
    {{/each}}

    <div class="newsletter-thankyou-block">
        <div class="inner">
            <div class="title-col">
                <h2>Thank You</h2>
            </div>
            <div class="text-col">
                {{#each thankYou.paragraphs}}
                <p style="margin: 0{{#if @first}}{{#unless @last}} 0 12px 0{{/unless}}{{/if}};">{{this}}</p>
                {{/each}}
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>Contact Us</h4>
                    <p><a href="https://wa.me/447561737986" target="_blank" rel="noopener noreferrer" class="whatsapp-button">Chat on WhatsApp</a></p>
                    <p><a href="https://mail.google.com/mail/?view=cm&fs=1&to=hello@chorltonbikes.coop" target="_blank" rel="noopener noreferrer" class="footer-link">hello@chorltonbikes.coop</a></p>
                    <p><a href="tel:+447561737986" class="footer-link">+44 7561 737986</a></p>
                    <p><a href="https://maps.app.goo.gl/LZXcpTXvTtkWwr8o9" target="_blank" rel="noopener noreferrer" class="footer-link">Find Us on Google Maps</a></p>
                </div>
                <div class="footer-section footer-logo-section">
                    <img src="../assets/images/real-living-wage-logo.webp" alt="Real Living Wage Employer" class="footer-logo">
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; {{footerYear}} Chorlton Bikes. All Rights Reserved. | <a href="../privacy-policy.html" class="footer-link">Privacy Policy</a></p>
            </div>
        </div>
    </footer>
    <script src="../script.js"></script>
</body>
</html>
